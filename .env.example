# ── Required ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# The full public shared-view URL from your browser's address bar.
# No account ownership or API key needed — this is a public view.
AIRTABLE_SHARED_VIEW_URL=https://airtable.com/appw7jfRXG6Joia2b/shrsfJpcHYJZat9Uk

# ── Optional ──────────────────────────────────────────────────
# How often to check for new listings (minutes). Default: 15
POLL_INTERVAL_MINUTES=15

# Path to the SQLite state file.
# On Railway with a persistent volume mounted at /data, use /data/state.db
DB_PATH=/data/state.db
